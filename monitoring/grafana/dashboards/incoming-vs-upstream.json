          "editorMode": "code",
          "expr": "sum(rate(erpc_network_request_received_total{project=~\"${project:regex}\", network=~\"${network:regex}\", user=~\"${user:regex}\", category=~\"${category:regex}\", finality=~\"${finality:regex}\"}[$__rate_interval]))",
